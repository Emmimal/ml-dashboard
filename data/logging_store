"""
Step 1: Logging Predictions and Ground Truth to a Database.

A minimal, dependency-free logging layer built on SQLite. This is
intentionally not Postgres or a managed warehouse — the schema is what
matters, and SQLite lets every reader run this end-to-end with zero setup.
Swapping the connection string for a Postgres DSN is a one-line change; the
schema and queries are otherwise portable.
"""

from __future__ import annotations

import json
import sqlite3
import time
from contextlib import contextmanager
from dataclasses import dataclass
from typing import Iterator, List, Optional, Sequence

import numpy as np

SCHEMA = """
CREATE TABLE IF NOT EXISTS predictions (
    id INTEGER PRIMARY KEY AUTOINCREMENT,
    batch_id INTEGER NOT NULL,
    row_in_batch INTEGER NOT NULL,
    features TEXT NOT NULL,         -- JSON-encoded feature vector
    predicted_class INTEGER NOT NULL,
    confidence REAL NOT NULL,
    scores TEXT NOT NULL,           -- JSON-encoded full probability vector
    true_class INTEGER,             -- NULL until ground truth arrives
    logged_at REAL NOT NULL,
    labeled_at REAL                 -- NULL until ground truth arrives
);

CREATE INDEX IF NOT EXISTS idx_predictions_batch ON predictions(batch_id);
CREATE INDEX IF NOT EXISTS idx_predictions_unlabeled ON predictions(true_class)
    WHERE true_class IS NULL;

CREATE TABLE IF NOT EXISTS monitor_reports (
    id INTEGER PRIMARY KEY AUTOINCREMENT,
    batch_id INTEGER NOT NULL,
    report_type TEXT NOT NULL,      -- 'feature' | 'prediction' | 'performance'
    payload TEXT NOT NULL,          -- JSON-encoded report
    created_at REAL NOT NULL
);

CREATE INDEX IF NOT EXISTS idx_reports_batch ON monitor_reports(batch_id, report_type);

CREATE TABLE IF NOT EXISTS alerts (
    id INTEGER PRIMARY KEY AUTOINCREMENT,
    batch_id INTEGER NOT NULL,
    severity TEXT NOT NULL,         -- 'warning' | 'critical'
    channel TEXT NOT NULL,          -- 'slack' | 'email' | 'log'
    message TEXT NOT NULL,
    sent_at REAL NOT NULL,
    delivered INTEGER NOT NULL DEFAULT 0
);
"""


@contextmanager
def get_connection(db_path: str) -> Iterator[sqlite3.Connection]:
    conn = sqlite3.connect(db_path)
    conn.row_factory = sqlite3.Row
    try:
        yield conn
        conn.commit()
    finally:
        conn.close()


def init_db(db_path: str) -> None:
    with get_connection(db_path) as conn:
        conn.executescript(SCHEMA)


@dataclass
class LoggedPrediction:
    batch_id: int
    row_in_batch: int
    features: np.ndarray
    predicted_class: int
    confidence: float
    scores: np.ndarray
    true_class: Optional[int] = None


def log_predictions(db_path: str, rows: Sequence[LoggedPrediction]) -> None:
    """Bulk-insert a batch of predictions. Call this at inference time, on
    every request — this is the real-time half of the pipeline."""
    now = time.time()
    with get_connection(db_path) as conn:
        conn.executemany(
            """
            INSERT INTO predictions
                (batch_id, row_in_batch, features, predicted_class,
                 confidence, scores, true_class, logged_at, labeled_at)
            VALUES (?, ?, ?, ?, ?, ?, ?, ?, ?)
            """,
            [
                (
                    r.batch_id,
                    r.row_in_batch,
                    json.dumps(r.features.tolist()),
                    int(r.predicted_class),
                    float(r.confidence),
                    json.dumps(r.scores.tolist()),
                    int(r.true_class) if r.true_class is not None else None,
                    now,
                    now if r.true_class is not None else None,
                )
                for r in rows
            ],
        )


def backfill_ground_truth(db_path: str, batch_id: int, y_true: np.ndarray) -> None:
    """Call this when delayed ground truth labels arrive for a batch. This
    is the lagging half of the pipeline — it's what unlocks the
    Performance Monitor layer for that batch."""
    now = time.time()
    with get_connection(db_path) as conn:
        rows = conn.execute(
            "SELECT id, row_in_batch FROM predictions WHERE batch_id = ? ORDER BY row_in_batch",
            (batch_id,),
        ).fetchall()
        if len(rows) != len(y_true):
            raise ValueError(
                f"Ground truth length {len(y_true)} does not match "
                f"{len(rows)} logged predictions for batch {batch_id}"
            )
        conn.executemany(
            "UPDATE predictions SET true_class = ?, labeled_at = ? WHERE id = ?",
            [(int(label), now, row["id"]) for row, label in zip(rows, y_true)],
        )


def load_batch(db_path: str, batch_id: int) -> dict:
    with get_connection(db_path) as conn:
        rows = conn.execute(
            "SELECT * FROM predictions WHERE batch_id = ? ORDER BY row_in_batch",
            (batch_id,),
        ).fetchall()
    X = np.array([json.loads(r["features"]) for r in rows])
    preds = np.array([r["predicted_class"] for r in rows])
    scores = np.array([json.loads(r["scores"]) for r in rows])
    has_labels = all(r["true_class"] is not None for r in rows)
    y_true = np.array([r["true_class"] for r in rows]) if has_labels else None
    return {"X": X, "preds": preds, "scores": scores, "y_true": y_true}


def list_batch_ids(db_path: str) -> List[int]:
    with get_connection(db_path) as conn:
        rows = conn.execute(
            "SELECT DISTINCT batch_id FROM predictions ORDER BY batch_id"
        ).fetchall()
    return [r["batch_id"] for r in rows]


class _NumpyEncoder(json.JSONEncoder):
    """Handles numpy scalar/bool types that sneak into dataclass __dict__
    payloads (e.g. np.bool_ from comparisons, np.float64 from aggregations)."""

    def default(self, obj):
        if isinstance(obj, np.bool_):
            return bool(obj)
        if isinstance(obj, np.integer):
            return int(obj)
        if isinstance(obj, np.floating):
            return float(obj)
        if isinstance(obj, np.ndarray):
            return obj.tolist()
        return super().default(obj)


def save_monitor_report(db_path: str, batch_id: int, report_type: str, payload: dict) -> None:
    with get_connection(db_path) as conn:
        conn.execute(
            """INSERT INTO monitor_reports (batch_id, report_type, payload, created_at)
               VALUES (?, ?, ?, ?)""",
            (batch_id, report_type, json.dumps(payload, cls=_NumpyEncoder), time.time()),
        )


def load_monitor_reports(db_path: str, report_type: Optional[str] = None) -> List[dict]:
    with get_connection(db_path) as conn:
        if report_type:
            rows = conn.execute(
                "SELECT * FROM monitor_reports WHERE report_type = ? ORDER BY batch_id",
                (report_type,),
            ).fetchall()
        else:
            rows = conn.execute(
                "SELECT * FROM monitor_reports ORDER BY batch_id"
            ).fetchall()
    return [
        {
            "batch_id": r["batch_id"],
            "report_type": r["report_type"],
            "payload": json.loads(r["payload"]),
            "created_at": r["created_at"],
        }
        for r in rows
    ]


def save_alert(db_path: str, batch_id: int, severity: str, channel: str, message: str, delivered: bool) -> None:
    with get_connection(db_path) as conn:
        conn.execute(
            """INSERT INTO alerts (batch_id, severity, channel, message, sent_at, delivered)
               VALUES (?, ?, ?, ?, ?, ?)""",
            (batch_id, severity, channel, message, time.time(), int(delivered)),
        )


def load_alerts(db_path: str) -> List[dict]:
    with get_connection(db_path) as conn:
        rows = conn.execute("SELECT * FROM alerts ORDER BY sent_at DESC").fetchall()
    return [dict(r) for r in rows]
