import pytest

from alerts.dispatch import AlertConfig, send_email_alert, send_slack_alert
from data.generators import (
    AbruptDriftGenerator,
    GradualDriftGenerator,
    LabelShiftGenerator,
    StableStreamGenerator,
)
from data.logging_store import (
    LoggedPrediction,
