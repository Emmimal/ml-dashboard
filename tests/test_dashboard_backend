def test_alert_below_severity_threshold_is_suppressed(capsys):
    config = AlertConfig(dry_run=True, min_severity_slack="critical")
    sent = send_slack_alert(config, "minor warning, unique-key-1", severity="warning")
    assert sent is False


def test_alert_at_or_above_threshold_fires(capsys):
    config = AlertConfig(dry_run=True, min_severity_slack="critical")
    sent = send_slack_alert(config, "critical issue, unique-key-2", severity="critical")
    assert sent is True
    captured = capsys.readouterr()
    assert "DRY RUN" in captured.out


def test_alert_rate_limiting_suppresses_duplicate(capsys):
    config = AlertConfig(dry_run=True, min_severity_slack="critical", rate_limit_seconds=300)
    msg = "duplicate test message unique-key-3"
    first = send_slack_alert(config, msg, severity="critical")
    second = send_slack_alert(config, msg, severity="critical")
    assert first is True
    assert second is False  # rate limited


def test_email_alert_dry_run_does_not_require_smtp_config(capsys):
    config = AlertConfig(dry_run=True, min_severity_email="critical")
    sent = send_email_alert(config, "subject unique-key-4", "body", severity="critical")
    assert sent is True
