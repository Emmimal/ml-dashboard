# Logging store
# ---------------------------------------------------------------------------

def test_init_db_creates_tables(tmp_db):
    # init_db should be idempotent — calling it twice should not raise
    init_db(tmp_db)
    init_db(tmp_db)


def test_log_and_load_predictions_round_trip(tmp_db):
    rows = [
        LoggedPrediction(
            batch_id=1,
            row_in_batch=i,
            features=np.array([1.0, 2.0, 3.0]),
            predicted_class=i % 2,
            confidence=0.9,
            scores=np.array([0.9, 0.1]),
        )
        for i in range(5)
    ]
    log_predictions(tmp_db, rows)
    batch = load_batch(tmp_db, 1)
    assert batch["X"].shape == (5, 3)
    assert batch["preds"].shape == (5,)
    assert batch["y_true"] is None  # no ground truth yet


def test_backfill_ground_truth_unlocks_labels(tmp_db):
    rows = [
        LoggedPrediction(
            batch_id=1,
            row_in_batch=i,
            features=np.array([1.0, 2.0]),
            predicted_class=0,
            confidence=0.8,
            scores=np.array([0.8, 0.2]),
        )
        for i in range(3)
    ]
    log_predictions(tmp_db, rows)
    backfill_ground_truth(tmp_db, 1, np.array([0, 1, 0]))
    batch = load_batch(tmp_db, 1)
    assert batch["y_true"] is not None
    np.testing.assert_array_equal(batch["y_true"], [0, 1, 0])


def test_backfill_length_mismatch_raises(tmp_db):
    rows = [
        LoggedPrediction(
            batch_id=1, row_in_batch=0, features=np.array([1.0]),
            predicted_class=0, confidence=0.5, scores=np.array([0.5, 0.5]),
        )
    ]
    log_predictions(tmp_db, rows)
    with pytest.raises(ValueError):
        backfill_ground_truth(tmp_db, 1, np.array([0, 1]))  # wrong length


def test_list_batch_ids_returns_sorted_distinct(tmp_db):
    for batch_id in [3, 1, 2, 1]:
        rows = [
            LoggedPrediction(
                batch_id=batch_id, row_in_batch=0, features=np.array([1.0]),
                predicted_class=0, confidence=0.5, scores=np.array([0.5, 0.5]),
            )
        ]
        log_predictions(tmp_db, rows)
    assert list_batch_ids(tmp_db) == [1, 2, 3]


def test_save_and_load_monitor_report_with_numpy_types(tmp_db):
    # Regression test: dataclass __dict__ payloads often carry np.bool_ /
    # np.float64, which the stdlib json encoder rejects without the custom
    # encoder in logging_store.py.
    payload = {
        "any_drift": np.bool_(True),
        "psi_values": {"f0": np.float64(0.234)},
        "batch_id": np.int64(1),
    }
    save_monitor_report(tmp_db, 1, "feature", payload)
    reports = load_monitor_reports(tmp_db, "feature")
    assert len(reports) == 1
    assert reports[0]["payload"]["any_drift"] is True


